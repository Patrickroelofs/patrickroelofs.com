---
import { Image } from 'astro:assets'

import ArrowBendDownRight from '../icons/phosphor/arrow-bend-down-right.astro'
import CityPhoto from '../images/patrick_city.png'
---

<footer class="mt-32 bg-hermes-200 pb-8 pt-12" id="footer">
	<div class="mx-auto flex h-auto max-w-screen-xl flex-col justify-between gap-36">
		<div class="flex flex-col items-center justify-between gap-12 px-4 lg:flex-row">
			<div class="flex flex-col gap-4">
				<p class="text-6xl font-bold">Interested in<br /> working together?</p>
				<div class="mt-8 flex flex-row gap-6">
					<ArrowBendDownRight size="32" />
					<a
						class="text-lg font-bold hover:underline focus:underline focus:outline-none"
						href="mailto:contact@patrickroelofs.com"
					>
						Email
					</a>
					<a
						class="text-lg font-bold hover:underline focus:underline focus:outline-none"
						href="https://www.linkedin.com/in/patrick-roelofs/"
						target="_blank"
					>
						Linkedin
					</a>
					<a
						class="text-lg font-bold hover:underline focus:underline focus:outline-none"
						href="https://github.com/Patrickroelofs"
						target="_blank"
					>
						Github
					</a>
				</div>
			</div>
			<div class="h-80 w-80 overflow-hidden rounded-full bg-hermes-300">
				<Image alt="" class="h-full w-full object-cover" loading="eager" src={CityPhoto} />
			</div>
		</div>
		<div class="font-medium">Made with ❤️</div>
	</div>
</footer>
