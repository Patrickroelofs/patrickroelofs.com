<footer class="mx-auto mt-64 flex min-h-72 max-w-screen-2xl flex-col">
	<div class="mb-12 flex flex-col gap-6">
		<span class="font-display text-5xl">Let's chat,</span>
		<a
			class="flex items-center gap-4 font-display text-7xl hover:underline hover:underline-offset-8"
			href="mailto:hi@patrickroelofs.com"
		>
			hi@patrickroelofs.com
		</a>
	</div>

	<div class="mb-12 mt-36 flex justify-between text-2xl">
		<p>
			Based in
			<a
				class="transition-all duration-300 ease-in-out hover:underline"
				href="https://www.google.com/maps?q=Nijmegen"
				target="_blank"
			>
				Nijmegen, the Netherlands
			</a>
		</p>
		<div class="flex gap-6">
			<a
				aria-label="external link to LinkedIn account"
				href="https://www.linkedin.com/in/patrick-roelofs/"
				target="_blank"
			>
				<span class="flex w-8">
					<svg viewBox="0 0 32 32">
						<path
							d="M28.778 1.004H3.191a2.185 2.185 0 0 0-2.186 2.159v25.672a2.186 2.186 0 0 0 2.186 2.161h25.612c1.2 0 2.175-.963 2.194-2.159V3.165a2.195 2.195 0 0 0-2.195-2.161h-.029.001zM9.9 26.562H5.446V12.251H9.9zM7.674 10.293a2.579 2.579 0 1 1 2.579-2.58v.004a2.577 2.577 0 0 1-2.577 2.577h-.003zm18.882 16.269h-4.441v-6.959c0-1.66-.034-3.795-2.314-3.795-2.316 0-2.669 1.806-2.669 3.673v7.082h-4.441V12.252h4.266v1.951h.058a4.686 4.686 0 0 1 4.22-2.312h-.009c4.5 0 5.332 2.962 5.332 6.817v7.855z"
						></path>
					</svg>
				</span>
			</a>
			<a
				aria-label="external link to Github account"
				href="https://www.github.com/patrickroelofs"
				target="_blank"
			>
				<span class="flex w-8">
					<svg viewBox="0 0 20 20">
						<path
							d="M10 0c5.523 0 10 4.59 10 10.253 0 4.529-2.862 8.371-6.833 9.728-.507.101-.687-.219-.687-.492 0-.338.012-1.442.012-2.814 0-.956-.32-1.58-.679-1.898 2.227-.254 4.567-1.121 4.567-5.059 0-1.12-.388-2.034-1.03-2.752.104-.259.447-1.302-.098-2.714 0 0-.838-.275-2.747 1.051A9.396 9.396 0 0 0 10 4.958a9.375 9.375 0 0 0-2.503.345C5.586 3.977 4.746 4.252 4.746 4.252c-.543 1.412-.2 2.455-.097 2.714-.639.718-1.03 1.632-1.03 2.752 0 3.928 2.335 4.808 4.556 5.067-.286.256-.545.708-.635 1.371-.57.262-2.018.715-2.91-.852 0 0-.529-.985-1.533-1.057 0 0-.975-.013-.068.623 0 0 .655.315 1.11 1.5 0 0 .587 1.83 3.369 1.21.005.857.014 1.665.014 1.909 0 .271-.184.588-.683.493C2.865 18.627 0 14.783 0 10.253 0 4.59 4.478 0 10 0"
