  </Section>
  <Section>
    <Heading level={5}>This is a level 5 heading</Heading>
    <Link href="#">Hello World</Link>
  </Section>
  <Section>
    <Heading level={6}>This is a level 6 heading</Heading>
    <Link href="#">Hello World</Link>
  </Section>
</BaseLayout>