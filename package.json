{
  "name": "patrickroelofs.com",
  "version": "1.0.0",
  "description": "A portfolio website for Patrick Roelofs",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:reset": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:fresh",
    "ci": "payload migrate && pnpm build"
  },
  "dependencies": {
    "@fontsource-variable/literata": "^5.1.1",
    "@payloadcms/next": "latest",
    "@payloadcms/payload-cloud": "latest",
    "@payloadcms/richtext-lexical": "latest",
    "@payloadcms/storage-vercel-blob": "latest",
    "@payloadcms/db-vercel-postgres": "latest",
    "@payloadcms/live-preview-react": "latest",
    "@payloadcms/ui": "latest",
    "@payloadcms/plugin-nested-docs": "latest",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "next": "15.1.5",
    "payload": "latest",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.32.6",
    "zod": "^3.24.1",
    "class-variance-authority": "^0.7.1",
    "@vercel/analytics": "^1.4.1",
    "@vercel/blob": "^0.27.1",
    "@phosphor-icons/core": "^2.1.1",
    "@phosphor-icons/react": "^2.1.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.1.5",
    "prettier": "^3.4.2",
    "typescript": "5.7.3",
    "@vercel/style-guide": "^6.0.0",
    "postcss": "^8.4.49",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "tailwindcss": "^4.0.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
