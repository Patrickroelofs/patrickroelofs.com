{
  "name": "patrickroelofs.com",
  "version": "1.0.0",
  "description": "A portfolio website for Patrick Roelofs",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "check": "cross-env NODE_OPTIONS=--no-deprecation biome check",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation biome lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "migrate": "cross-env IS_BUILD=true NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:reset": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:fresh"
  },
  "dependencies": {
    "@fontsource-variable/literata": "^5.1.1",
    "@payloadcms/db-postgres": "3.29.0",
    "@payloadcms/live-preview-react": "3.29.0",
    "@payloadcms/next": "3.29.0",
    "@payloadcms/plugin-seo": "3.29.0",
    "@payloadcms/richtext-lexical": "^3.29.0",
    "@payloadcms/storage-s3": "3.29.0",
    "@payloadcms/ui": "3.29.0",
    "@phosphor-icons/core": "^2.1.1",
    "@phosphor-icons/react": "^2.1.7",
    "class-variance-authority": "^0.7.1",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "gsap": "^3.12.7",
    "libsql": "0.5.0-pre.6",
    "next": "15.1.5",
    "next-intl": "^3.26.3",
    "payload": "3.29.0",
    "plaiceholder": "^3.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.32.6",
    "shiki": "^3.1.0",
    "tm-grammars": "^1.22.19"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.5.4",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "postcss": "^8.4.49",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "sharp"]
  }
}
