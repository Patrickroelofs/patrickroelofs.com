    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/style-guide": "^6.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prettier": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.0-beta.4",
    "typescript": "^5.7.2"
  }
