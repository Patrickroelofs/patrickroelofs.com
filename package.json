{
  "name": "patrickroelofs.com",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:reset": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:fresh",
    "ci": "payload migrate && pnpm build"
  },
  "prettier": "@vercel/style-guide/prettier",
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource/lato": "^5.1.1",
    "@payloadcms/db-vercel-postgres": "^3.16.0",
    "@payloadcms/email-resend": "^3.16.0",
    "@payloadcms/live-preview-react": "^3.16.0",
    "@payloadcms/next": "^3.16.0",
    "@payloadcms/richtext-lexical": "^3.16.0",
    "@payloadcms/storage-vercel-blob": "^3.16.0",
    "@payloadcms/ui": "^3.16.0",
    "@phosphor-icons/core": "^2.1.1",
    "@phosphor-icons/react": "^2.1.7",
    "class-variance-authority": "^0.7.1",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "next": "^15.1.4",
    "payload": "^3.16.0",
    "plaiceholder": "^3.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.32.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.5.4",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@vercel/style-guide": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "~8.57.1",
    "eslint-config-next": "15.1.2",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
